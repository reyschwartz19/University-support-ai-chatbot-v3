# ============================================
# University Chatbot V3 - Environment Variables
# ============================================

# Database Configuration (Supabase PostgreSQL)
# Get this from Supabase: Settings > Database > Connection string (URI)
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres

# Flask Configuration
FLASK_ENV=development
SECRET_KEY=change-this-to-a-random-secret-key-in-production

# Gemini API Key (Google AI Studio)
GEMINI_API_KEY=your-gemini-api-key-here

# CORS Origins (comma-separated, set to your Vercel domains in production)
# Example: https://your-frontend.vercel.app,https://your-admin.vercel.app
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
